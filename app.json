{
  "expo": {
    "name": "ApsaraAstro",
    "slug": "apsara-astro-mobile",
    "scheme": "apsaraastro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo_apsara.png",
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./src/assets/logo_apsara.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "./plugins/withCleartextTraffic"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apsaraastro.mobile"
    },
    "android": {
      "package": "com.apsaraastro.mobile",
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo_apsara.png",
        "backgroundColor": "#fff7e8"
      }
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiUrl": "https://apsraastro.com",
      "astroApiUrl": "https://apsraastro.com",
      "eas": {
        "projectId": "82173d52-de95-4a59-b830-b36228361940"
      }
    },
    "owner": "shivam_onecorp2"
  }
}
